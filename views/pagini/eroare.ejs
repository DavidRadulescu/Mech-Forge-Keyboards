<!DOCTYPE html>
<html lang="ro">
<head>
    <%- include('../fragmente/head') %>
    <title><%= locals.titlu %></title>
</head>
<body id="top">
    <%- include('../fragmente/header') %>

    <main>
        <section style="text-align: center; padding: 100px 20px;">
            <i class="fa-solid fa-triangle-exclamation" style="font-size: 4rem; color: var(--primary-color);"></i>
            <h2 style="margin-top: 20px;"><%= locals.titlu %></h2>
            <p style="font-size: 1.2rem; margin: 20px 0;"><%= locals.text %></p>
            <img src="<%= locals.imagine %>" alt="Imagine Eroare" style="max-width: 300px; border-radius: 10px;">
            <br><br>
            <a href="/" style="color: var(--primary-color); font-weight: bold; text-decoration: none;">&larr; Întoarce-te pe pagina principală</a>
        </section>
    </main>

    <%- include('../fragmente/footer') %>
</body>
</html>